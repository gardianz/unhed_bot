# Required for live trading. Keep this secret.
UNHEDGED_API_KEY=ak_xxxxxxxxxxxxxxxxxxxxxxxx
UNHEDGED_API_BASE=https://api.unhedged.gg

# Strategy selector:
# 1 = legacy signed-range strategy
# 2 = absolute M5 segment strategy
SELECT_STRATEGY=1

LOG_LEVEL=INFO

# Connection timeout for opening HTTP connections.
HTTP_CONNECT_TIMEOUT_SEC=3

# Bet size per order in CC.
STAKE_CC=10

# Read timeout after connection is established.
HTTP_TIMEOUT_SEC=10
POLL_INTERVAL_SEC=1

# Decision is only allowed when time left <= this value.
DECISION_WINDOW_SEC=10
MARKET_DETAIL_REFRESH_SEC=3
PRICE_HISTORY_REFRESH_SEC=1
RATE_LIMIT_BACKOFF_SEC=10

# Optional manual market IDs. Leave blank to auto-discover active markets.
BTC_MARKET_ID=
SOL_MARKET_ID=
ETH_MARKET_ID=

# Only used by strategy 1. Strategy 2 ignores these filters.
BTC_AVG1_MIN=50
SOL_AVG1_MIN=0.18
ETH_AVG1_MIN=2.25

SIGNAL_HISTORY_PATH=signal_history.jsonl
PENDING_BETS_PATH=pending_bets.json

# Optional Telegram notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TIMEOUT_SEC=10
TELEGRAM_PREFIX=Unhedged Bot
TELEGRAM_LOG_LEVEL=ERROR
TELEGRAM_POSITION_UPDATE_SEC=10
